<?xml version="1.0" ?>
<mujoco model="maze_robot">
  <!-- ========== COMPILATION OPTIONS ========== -->
  <compiler angle="radian" inertiafromgeom="true" />
  
  <!-- ========== GLOBAL SETTINGS ========== -->
  <option timestep="0.001" viscosity="0.0" gravity="0 0 -9.81">
    <flag warmstart="disable" />
  </option>
  
  <!-- ========== ASSETS ========== -->
  <asset>
    <!-- Materials for visualization -->
    <material name="robot_body" rgba="0.7 0.7 0.7 1.0" />
    <material name="wheel" rgba="0.2 0.2 0.2 1.0" />
    <material name="caster" rgba="0.3 0.3 0.7 1.0" />
    <material name="groundplane" rgba="0.4 0.8 0.4 1.0" />
  </asset>
  
  <!-- ========== BODIES ========== -->
  <worldbody>
    <!-- World ground plane -->
    <geom name="ground" type="plane" size="10 10 0.1" pos="0 0 -0.1" material="groundplane" />
    
    <!-- ========== ROBOT BODY ========== -->
    <body name="robot" pos="0 0 0.04" euler="0 0 0">
      <joint name="root" type="free" />
      <!-- Main chassis (box) -->
      <inertial pos="0 0 0" mass="0.5" diaginertia="0.01 0.01 0.01" />
      <geom name="chassis" type="box" size="0.05 0.04 0.02" material="robot_body" />
      
      <!-- Left wheel -->
      <body name="left_wheel" pos="0 0.04 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001" />
        <geom name="left_wheel_geom" type="cylinder" size="0.025" fromto="0 -0.01 0 0 0.01 0" material="wheel" />
        <joint name="left_wheel" type="hinge" axis="0 1 0" pos="0 0 0" />
      </body>
      
      <!-- Right wheel -->
      <body name="right_wheel" pos="0 -0.04 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001" />
        <geom name="right_wheel_geom" type="cylinder" size="0.025" fromto="0 -0.01 0 0 0.01 0" material="wheel" />
        <joint name="right_wheel" type="hinge" axis="0 1 0" pos="0 0 0" />
      </body>
      
      <!-- Caster wheel (passive ball for support) -->
      <body name="caster" pos="0.04 0 -0.015">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.0001 0.0001 0.0001" />
        <geom name="caster_geom" type="sphere" size="0.01" material="caster" />
        <joint name="caster_x" type="slide" axis="1 0 0" pos="0 0 0" limited="false" />
        <joint name="caster_y" type="slide" axis="0 1 0" pos="0 0 0" limited="false" />
        <joint name="caster_z" type="slide" axis="0 0 1" pos="0 0 0" limited="false" />
      </body>
      
      <!-- ========== RANGEFINDER SENSORS ========== -->
      <!-- Front rangefinder (x-axis, +x direction) -->
      <site name="sensor_front" type="sphere" size="0.002" pos="0.055 0 0" rgba="1 0 0 0.5" />
      
      <!-- Front-left rangefinder (45 degrees left of front) -->
      <site name="sensor_front_left" type="sphere" size="0.002" pos="0.045 0.035 0" rgba="1 0 0 0.5" />
      
      <!-- Left rangefinder (y-axis, +y direction) -->
      <site name="sensor_left" type="sphere" size="0.002" pos="0 0.050 0" rgba="1 0 0 0.5" />
      
      <!-- Front-right rangefinder (45 degrees right of front) -->
      <site name="sensor_front_right" type="sphere" size="0.002" pos="0.045 -0.035 0" rgba="1 0 0 0.5" />
      
      <!-- Right rangefinder (y-axis, -y direction) -->
      <site name="sensor_right" type="sphere" size="0.002" pos="0 -0.050 0" rgba="1 0 0 0.5" />
    </body>
  </worldbody>
  
  <!-- ========== ACTUATORS ========== -->
  <actuator>
    <!-- Left wheel motor (torque controlled) -->
    <motor name="left_wheel_motor" joint="left_wheel" ctrlrange="-1.0 1.0" />
    
    <!-- Right wheel motor (torque controlled) -->
    <motor name="right_wheel_motor" joint="right_wheel" ctrlrange="-1.0 1.0" />
  </actuator>
  
  <!-- ========== SENSORS ========== -->
  <sensor>
    <!-- Joint feedback -->
    <jointvel name="left_wheel_vel" joint="left_wheel" />
    <jointvel name="right_wheel_vel" joint="right_wheel" />
    <jointpos name="left_wheel_pos" joint="left_wheel" />
    <jointpos name="right_wheel_pos" joint="right_wheel" />
    
    <!-- Position of robot body -->
    <framepos name="robot_xpos" objtype="body" objname="robot" />
    <framequat name="robot_quat" objtype="body" objname="robot" />
    <framelinvel name="robot_xvelp" objtype="body" objname="robot" />
    <frameangvel name="robot_xangvel" objtype="body" objname="robot" />
    
    <!-- Rangefinder sensors for wall-following -->
    <rangefinder name="range_front" site="sensor_front" />
    <rangefinder name="range_front_left" site="sensor_front_left" />
    <rangefinder name="range_left" site="sensor_left" />
    <rangefinder name="range_front_right" site="sensor_front_right" />
    <rangefinder name="range_right" site="sensor_right" />
  </sensor>
</mujoco>
